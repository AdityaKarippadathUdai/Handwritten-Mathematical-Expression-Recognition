PROJECT_NAME="Handwritten Mathematical Expression Recognition"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,http://localhost:5173"

# Local uvicorn development defaults. Docker Compose overrides APP_RUNTIME and DATABASE_HOST.
APP_RUNTIME=local
ENVIRONMENT="development"
DEBUG=true
DATABASE_DRIVER="postgresql+psycopg2"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_NAME="hmer"
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"

# Optional full override. Production deployments should set this explicitly.
# DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/hmer"

PIX2TEX_CACHE_DIR=".cache/pix2tex"
YOLO_MODEL_PATH="ml_models/yolo/best.pt"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hmer
